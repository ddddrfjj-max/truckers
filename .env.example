# ─── Database ─────────────────────────────────────────────────────────────────
# Railway provides this automatically via the Postgres plugin.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freightflow"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-min-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (your Vercel URL).
FRONTEND_URL=https://your-app.vercel.app

# ─── File Storage ─────────────────────────────────────────────────────────────
# LOCAL: Mount a Railway Volume at /data/uploads and set UPLOAD_DIR=/data/uploads
# S3/R2 (recommended for production): configure the variables below.
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# AWS S3 / Cloudflare R2 (optional — replace local storage for production)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=                  # Cloudflare R2 only

# ─── Web App (Vercel) ─────────────────────────────────────────────────────────
# Set to your Railway API service URL (e.g. https://freightflow-api.up.railway.app)
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://your-app.vercel.app
