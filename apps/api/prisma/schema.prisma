generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SHIPPER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum DriverVerificationStatus {
  NOT_SUBMITTED
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  DRIVERS_LICENSE_FRONT
  DRIVERS_LICENSE_BACK
  VEHICLE_REGISTRATION
  INSURANCE_CERTIFICATE
  PROFILE_PHOTO
  GOVERNMENT_ID
  BUSINESS_LICENSE
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShipmentStatus {
  DRAFT
  OPEN
  BIDDING
  BOOKED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  CONFIRMED
  DRIVER_EN_ROUTE
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
}

enum CargoType {
  GENERAL
  FRAGILE
  HAZARDOUS
  REFRIGERATED
  OVERSIZED
  LIVESTOCK
  ELECTRONICS
}

enum VehicleType {
  SEDAN
  VAN
  BOX_TRUCK
  FLATBED
  SEMI_TRUCK
  REFRIGERATED_TRUCK
  TANKER
  PICKUP
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  role          Role
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  profile         Profile?
  shipments       Shipment[]
  bids            Bid[]
  bookingsAsDriver Booking[] @relation("DriverBookings")
  documents       Document[]
  driverProfile   DriverProfile?
  notifications   Notification[]
  auditLogs       AuditLog[]
  sentMessages    ChatMessage[]   @relation("SentMessages")

  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  phone       String?
  avatarUrl   String?
  company     String?
  address     String?
  city        String?
  state       String?
  country     String   @default("US")
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model DriverProfile {
  id                   String                   @id @default(cuid())
  userId               String                   @unique
  licenseNumber        String?
  licenseExpiry        DateTime?
  vehicleType          VehicleType?
  vehicleMake          String?
  vehicleModel         String?
  vehicleYear          Int?
  vehiclePlate         String?
  vehicleCapacityTons  Float?
  verificationStatus   DriverVerificationStatus @default(NOT_SUBMITTED)
  verificationNotes    String?
  verifiedAt           DateTime?
  verifiedBy           String?
  rating               Float                    @default(0)
  totalTrips           Int                      @default(0)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("driver_profiles")
}

model Shipment {
  id              String         @id @default(cuid())
  shipperId       String
  title           String
  description     String?
  status          ShipmentStatus @default(DRAFT)
  cargoType       CargoType      @default(GENERAL)
  weightKg        Float
  lengthCm        Float?
  widthCm         Float?
  heightCm        Float?
  specialHandling String?

  pickupAddress   String
  pickupCity      String
  pickupState     String
  pickupZip       String?
  pickupLat       Float?
  pickupLng       Float?
  pickupDate      DateTime

  deliveryAddress String
  deliveryCity    String
  deliveryState   String
  deliveryZip     String?
  deliveryLat     Float?
  deliveryLng     Float?
  deliveryDate    DateTime?

  budgetMin       Float?
  budgetMax       Float?
  vehicleRequired VehicleType?

  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  publishedAt     DateTime?
  cancelledAt     DateTime?

  shipper  User      @relation(fields: [shipperId], references: [id])
  bids     Bid[]
  booking  Booking?
  images   ShipmentImage[]

  @@map("shipments")
}

model ShipmentImage {
  id         String   @id @default(cuid())
  shipmentId String
  url        String
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_images")
}

model Bid {
  id          String    @id @default(cuid())
  shipmentId  String
  driverId    String
  amount      Float
  currency    String    @default("USD")
  status      BidStatus @default(PENDING)
  note        String?
  estimatedDeliveryDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  withdrawnAt DateTime?
  respondedAt DateTime?

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  driver   User     @relation(fields: [driverId], references: [id])
  booking  Booking?

  @@unique([shipmentId, driverId])
  @@map("bids")
}

model Booking {
  id              String        @id @default(cuid())
  shipmentId      String        @unique
  bidId           String        @unique
  driverId        String
  driverProfileId String
  agreedAmount    Float
  currency        String        @default("USD")
  status          BookingStatus @default(CONFIRMED)

  pickupConfirmedAt   DateTime?
  inTransitAt         DateTime?
  deliveredAt         DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?

  trackingNotes   String?
  driverRating    Float?
  shipperRating   Float?
  driverReview    String?
  shipperReview   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipment      Shipment      @relation(fields: [shipmentId], references: [id])
  bid           Bid           @relation(fields: [bidId], references: [id])
  driver        User          @relation("DriverBookings", fields: [driverId], references: [id])
  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id])
  messages      ChatMessage[]

  @@map("bookings")
}

model ChatMessage {
  id        String   @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation("SentMessages", fields: [senderId], references: [id])

  @@map("chat_messages")
}

model Document {
  id         String         @id @default(cuid())
  userId     String
  type       DocumentType
  status     DocumentStatus @default(PENDING)
  url        String
  filename   String
  mimeType   String
  sizeBytes  Int
  notes      String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  company   String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
