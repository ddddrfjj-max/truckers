    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.2.1",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
